{
  "expo": {
    "name": "industrial-asset-health-monitor",
    "slug": "industrial-asset-health-monitor",
    "version": "1.0.0",
    "scheme": "industrial-asset-health-monitor",
    "platforms": [
      "ios",
      "android"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(IAHL) needs access to your Camera.",
          "microphonePermissionText": "$(IAHL) needs access to your Microphone."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "$(IAHL) needs access to your Camera."
      },
      "bundleIdentifier": "com.edmirsoares.industrialassethealthmonitor"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.edmirsoares.industrialassethealthmonitor"
    }
  }
}
